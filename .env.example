# ============================================================
# KompetenzHub – Environment-Vorlage
# Kopiere diese Datei nach `.env` und passe die Werte an.
# ============================================================

# ----- PostgreSQL -----
POSTGRES_USER=kompetenzhub
POSTGRES_PASSWORD=kompetenzhub
POSTGRES_DB=kompetenzhub
POSTGRES_PORT=5432

# Prisma / NestJS Verbindungs-URL
DATABASE_URL=postgresql://kompetenzhub:kompetenzhub@localhost:5432/kompetenzhub?schema=public

# ----- Redis (Jobs / BullMQ) -----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- MinIO / S3 (Objektspeicher) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=kompetenzhub
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ----- API -----
API_PORT=3001

# ----- Web (Next.js) -----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://api.kompetenzhub.ch
# Multi-Tenant: Basisdomain für die Subdomain-Ableitung im Browser
# (muss zu TENANT_BASE_DOMAIN passen). Leer lassen für lokale Entwicklung.
NEXT_PUBLIC_TENANT_BASE_DOMAIN=kompetenzhub.ch

# ----- Auth (API-JWT & RBAC) -----
# Signaturschlüssel für API-JWT (HS256). In Produktion zwingend setzen!
JWT_SIGNING_KEY=fsdf-435543f-45632-123789-1456-dsf-sfdadf
# Token-Lebensdauer in Sekunden (Default 15 min)
JWT_TTL_SECONDS=5400
# Dev-Login-Endpoint (/api/v1/auth/dev-login) aktivieren – in Produktion auf false!
DEV_LOGIN_ENABLED=true
#Hier stelt man ein, ob der Admin-Login im Frontend angezeigt werden soll. In Produktion auf false!
SHOW_ADMIN_LOGIN=true
# Geteiltes Secret für /auth/exchange (Frontend BFF → API). Leer = ungeschützt (nur Dev).
AUTH_EXCHANGE_SECRET=fsdf-435543f-123456-7890-f56578-dsf-sdfsdf
# ----- Multi-Tenant (Mandanten pro Subdomain) -----
# Default-Mandant, wenn aus dem Host keine Subdomain ableitbar ist (z. B. localhost).
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_SLUG=demo
# Basisdomain für die Subdomain-Auflösung: schule-a.<BASISDOMAIN> → Mandant "schule-a".
# Leer lassen für lokale Entwicklung (localhost → Default-Mandant).
TENANT_BASE_DOMAIN=kompetenzhub.ch
# Leer lassen für lokale Entwicklung (localhost → Default-Mandant).
#zusätzliche Origins außerhalb der Basisdomain gedacht (z. B. eine Schule mit eigener Domain oder eine separate Frontend-URL). 
#CORS_ALLOWED_ORIGINS=https://a.ch, https://b.ch
# Plattform-Admins (tenant-übergreifend): dürfen Schulen anlegen/verwalten.

SUPERADMIN_EMAILS=mein@email.com
# Schuladmin-Bootstrap: kommaseparierte E-Mails, die beim Login ADMIN-Rechte erhalten.
# Beispiel: ADMIN_EMAILS=schulleitung@schule.ch,ict@schule.ch, admin@schule.ch
ADMIN_EMAILS=mein@email.com

# ----- Rate Limiting (pro IP) -----
# Grosszügig, da ganze Klassen hinter einer Schul-IP (NAT) arbeiten können.
THROTTLE_TTL=60000
THROTTLE_LIMIT=300
THROTTLE_AUTH_LIMIT=60

# ----- Container-Deployment (docker compose --profile app) -----
# Browser-erreichbare URLs (NICHT die internen Container-Namen!).
# Lokal: localhost; produktiv: die öffentliche(n) Domain(s) bzw. via Reverse Proxy.
API_PUBLIC_URL=https://api.kompetenzhub.ch
WEB_PUBLIC_URL=https://demo.kompetenzhub.ch
S3_PUBLIC_URL=https://s3.kompetenzhub.ch
# Für den produktiven Container-Betrieb JWT_SIGNING_KEY und AI_CONFIG_ENC_KEY
# zwingend auf starke, geheime Werte ändern (sonst startet die API nicht).

# ----- KI-Konfiguration (FA-34) -----
# Schlüssel zur Verschlüsselung gespeicherter KI-API-Keys (AES-256-GCM).
# In Produktion zwingend einen starken, geheimen Wert setzen!
AI_CONFIG_ENC_KEY=ff-553423-123456-453-789456123-dfrtre
# Stub-Modus: KI-Aufrufe liefern deterministische Antworten ohne externen Call
# (nur für Tests/Smokes; in Produktion NICHT setzen bzw. auf 0 lassen).
# AI_STUB_MODE=0
# Erlaubte Web-Origin für CORS (Cookies)
NEXT_PUBLIC_WEB_URL=https://demo.kompetenzhub.ch

# ----- Auth (OIDC) – Frontend (NextAuth), optional bis IdP angebunden -----
AUTH_MICROSOFT_CLIENT_ID=noch-zu-setzen
AUTH_MICROSOFT_CLIENT_SECRET=noch-zu-setze
#in Github:unter Settings -> Developer settings -> OAuth Apps -> New OAuth App
AUTH_GITHUB_CLIENT_ID=noch-zu-setzen        # OAuth App Client ID aus GitHub
AUTH_GITHUB_CLIENT_SECRET=noch-zu-setzen     # OAuth App Client Secret aus GitHub
# Lösen unter: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_CLIENT_ID=noch-zu-setzen.apps.googleusercontent.com
AUTH_GOOGLE_CLIENT_SECRET=noch-zu-setzen
NEXTAUTH_SECRET= mein-dev-nextauth-secret-change-me-in-production
NEXTAUTH_URL=https://demo.kompetenzhub.ch
# Multi-Tenant: Origin pro Request aus X-Forwarded-Host ableiten (statt fixem
# NEXTAUTH_URL), damit der OAuth-Rücksprung auf der richtigen Schul-Subdomain landet.
# Wird automatisch aktiv, sobald TENANT_BASE_DOMAIN gesetzt ist; in Produktion mit
# mehreren Subdomains explizit auf true setzen. Lokal (localhost) leer lassen.
AUTH_TRUST_HOST=true

# ----- Eigener Identity-Provider (Logto) – Self-Service-Registrierung -----
# Laeuft als eigener Container (siehe docker-compose_dev.yaml, Service "logto").
# OIDC-Endpoint:   http://localhost:3011   | Admin-Konsole: http://localhost:3012
# Einrichtung:
#   1. docker compose -f docker-compose_dev.yaml up -d logto logto-init
#      (logto-init stellt die Registrierung automatisch auf E-Mail+Passwort um –
#       KompetenzHub identifiziert Nutzer ueber die E-Mail, ein Username allein reicht nicht.)
#   2. Admin-Konsole http://localhost:3012 oeffnen, Admin-Konto anlegen.
#   3. Applications -> Create -> "Traditional Web" -> Name z. B. "KompetenzHub Web".
#   4. Redirect URI: http://localhost:3000/api/auth/callback/kompetenzhub
#      Post sign-out redirect URI: http://localhost:3000/login
#   5. App-Id/App-Secret unten eintragen. Issuer = ENDPOINT + "/oidc".
KOMPETENZHUB_OIDC_ISSUER=https://auth.kompetenzhub.ch/oidc
KOMPETENZHUB_OIDC_CLIENT_ID=noch-zu-setzen
KOMPETENZHUB_OIDC_CLIENT_SECRET=noch-zu-setzen
# Browser-erreichbare URLs des Logto-Containers (fuer abweichende Ports anpassen).
KOMPETENZHUB_OIDC_ENDPOINT=https://auth.kompetenzhub.ch
KOMPETENZHUB_ADMIN_ENDPOINT=https://authadmin.kompetenzhub.ch


# ----- E-Mail-Versand (SMTP / Nodemailer) -----
# Ohne SMTP_HOST ist der Versand deaktiviert (No-op) – die App läuft normal weiter.
# Empfehlung Schulkontext: ein EU/CH-SMTP-Server (DSG/DSGVO). Beispiel-Ports:
#   587 + SMTP_SECURE=false (STARTTLS, üblich) | 465 + SMTP_SECURE=true (implizites TLS)
#SMTP_HOST=localhost
#SMTP_PORT=1025

SMTP_HOST=email.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=meine@email.com
SMTP_PASS=noch-zu-setzen
# Absender-Adresse der ausgehenden Mails (Einladung, Tages-Digest um 04:00).
MAIL_FROM=KompetenzHub <info@email.com>



