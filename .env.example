# ============================================================
# KompetenzHub – Environment-Vorlage
# Kopiere diese Datei nach `.env` und passe die Werte an.
# ============================================================

# ----- PostgreSQL -----
POSTGRES_USER=kompetenzhub
POSTGRES_PASSWORD=kompetenzhub
POSTGRES_DB=kompetenzhub
POSTGRES_PORT=5432

# Prisma / NestJS Verbindungs-URL
DATABASE_URL=postgresql://kompetenzhub:kompetenzhub@localhost:5432/kompetenzhub?schema=public

# ----- Redis (Jobs / BullMQ) -----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- MinIO / S3 (Objektspeicher) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=kompetenzhub
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ----- API -----
API_PORT=3001

# ----- Web (Next.js) -----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----- Auth (API-JWT & RBAC) -----
# Signaturschlüssel für API-JWT (HS256). In Produktion zwingend setzen!
JWT_SIGNING_KEY=dev-insecure-signing-key-change-me
# Token-Lebensdauer in Sekunden (Default 15 min)
JWT_TTL_SECONDS=900
# Dev-Login-Endpoint (/api/v1/auth/dev-login) aktivieren – in Produktion auf false!
DEV_LOGIN_ENABLED=true
#Hier stelt man ein, ob der Admin-Login im Frontend angezeigt werden soll. In Produktion auf false!
SHOW_ADMIN_LOGIN=true
# Geteiltes Secret für /auth/exchange (Frontend BFF → API). Leer = ungeschützt (nur Dev).
AUTH_EXCHANGE_SECRET=
# Standard-Mandant (MVP: ein aktiver Tenant)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
# Schuladmin-Bootstrap: kommaseparierte E-Mails, die beim Login ADMIN-Rechte erhalten.
# Beispiel: ADMIN_EMAILS=schulleitung@schule.ch,ict@schule.ch, admin@schule.ch
ADMIN_EMAILS=

# ----- Rate Limiting (pro IP) -----
# Grosszügig, da ganze Klassen hinter einer Schul-IP (NAT) arbeiten können.
THROTTLE_TTL=60000
THROTTLE_LIMIT=300
THROTTLE_AUTH_LIMIT=60

# ----- Container-Deployment (docker compose --profile app) -----
# Browser-erreichbare URLs (NICHT die internen Container-Namen!).
# Lokal: localhost; produktiv: die öffentliche(n) Domain(s) bzw. via Reverse Proxy.
API_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000
S3_PUBLIC_URL=http://localhost:9000
# Für den produktiven Container-Betrieb JWT_SIGNING_KEY und AI_CONFIG_ENC_KEY
# zwingend auf starke, geheime Werte ändern (sonst startet die API nicht).

# ----- KI-Konfiguration (FA-34) -----
# Schlüssel zur Verschlüsselung gespeicherter KI-API-Keys (AES-256-GCM).
# In Produktion zwingend einen starken, geheimen Wert setzen!
AI_CONFIG_ENC_KEY=dev-insecure-ai-config-key-change-me
# Stub-Modus: KI-Aufrufe liefern deterministische Antworten ohne externen Call
# (nur für Tests/Smokes; in Produktion NICHT setzen bzw. auf 0 lassen).
# AI_STUB_MODE=0
# Erlaubte Web-Origin für CORS (Cookies)
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# ----- Auth (OIDC) – Frontend (NextAuth), optional bis IdP angebunden -----
# Gehe auf https://entra.microsoft.com/.

# AUTH_MICROSOFT_CLIENT_ID=        # App-Registrierung in Azure AD (Application ID)
# AUTH_MICROSOFT_CLIENT_SECRET=    # Client-Secret der App-Registrierung
# AUTH_MICROSOFT_TENANT_ID=common  # 'common' (Org + persönlich), 'organizations' oder Tenant-GUID
# Lösen unter: https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_CLIENT_ID=           # OAuth 2.0-Client-ID aus der Google Cloud Console
# AUTH_GOOGLE_CLIENT_SECRET=       # OAuth 2.0-Client-Secret
#in Github:unter Settings -> Developer settings -> OAuth Apps -> New OAuth App
# AUTH_GITHUB_CLIENT_ID=           # OAuth App Client ID aus GitHub
# AUTH_GITHUB_CLIENT_SECRET=       # OAuth App Client Secret aus GitHub
NEXTAUTH_SECRET=dev-nextauth-secret-change-me-in-production
NEXTAUTH_URL=http://localhost:3000


