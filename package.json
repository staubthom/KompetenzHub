{
  "name": "kompetenzhub",
  "version": "0.1.0",
  "private": true,
  "description": "KompetenzHub – Kompetenzmatrix-Plattform (Monorepo)",
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "plugins/contracts",
    "plugins/sdk",
    "plugins/packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build:packages": "npm run build --workspace plugins/contracts --workspace plugins/sdk",
    "build": "npm run build:packages && npm run build --workspaces --if-present",
    "typecheck": "npm run build:packages && npm run typecheck --workspaces --if-present",
    "lint": "eslint \"apps/**/*.{ts,tsx,js,jsx}\"",
    "test": "npm run build:packages && npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prisma:migrate": "npm run prisma:migrate --workspace apps/api",
    "prisma:generate": "npm run prisma:generate --workspace apps/api"
  },
  "overrides": {
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^8.2.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.7.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
