// KompetenzHub – Prisma-Schema (Sprint 0, MVP-Kern)
// Basis: docs/05-datenmodell.md. Abgebildet sind Mandant/Benutzer sowie die
// Kern-Matrix-Struktur (Modul → Matrix → Bänder × Gütestufen → Felder → Deskriptoren).
// Weitere Entitäten (Evidence, Submission, Evaluation, AI, LearningPath, Class …)
// folgen in späteren Sprints.

generator client {
  provider      = "prisma-client-js"
  // "native" für lokale Entwicklung, musl-Target für das Alpine-Docker-Image
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Role {
  ADMIN
  TEACHER
  LEARNER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum AuthProvider {
  MICROSOFT
  GOOGLE
  GITHUB
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum Locale {
  de
  fr
  it
  en
}

enum ModuleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CompetenceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ClassStatus {
  ACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  PENDING
  REMOVED
}

enum EvidenceType {
  QUIZ
  FILE_UPLOAD
}

enum SubmissionStatus {
  OPEN
  SUBMITTED
  IN_REVIEW
  GRADED
  REJECTED
  EXPIRED
}

enum AchievedLevel {
  NOT_MET
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EvaluationChangeType {
  CREATED
  UPDATED
  REJECTED
  REOPENED
}

enum EvaluationSource {
  TEACHER
  AI
}

// ============================================================
// Mandant & Benutzer
// ============================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branding    TenantBranding?
  users       Membership[]
  modules     Module[]
  classes     Class[]
  invitations Invitation[]
}

model TenantBranding {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  primaryColor   String   @default("#2563eb")
  secondaryColor String?
  logoLightKey   String?
  logoDarkKey    String?
  faviconKey     String?
  displayName    String?
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  displayName  String
  authProvider AuthProvider
  externalId   String
  avatarUrl    String?
  locale       Locale       @default(de)
  theme        String       @default("light") // Anzeigemodus: light | dark | gray
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships       Membership[]
  ownedModules      Module[]            @relation("ModuleOwner")
  ownedClasses      Class[]             @relation("ClassOwner")
  coTeachings       ClassTeacher[]      @relation("ClassCoTeacher")
  enrollments       Enrollment[]
  evaluations       Evaluation[]
  evaluationChanges EvaluationHistory[]

  @@unique([authProvider, externalId])
}

model Membership {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String
  role      Role
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, role])
  @@index([tenantId])
  @@index([userId])
}

// ============================================================
// Einladungen / Zugangssteuerung (Schuladmin)
// ============================================================
// Steuert, wer sich mit welcher Rolle anmelden darf. Eine offene
// Einladung wird beim ersten Login der passenden E-Mail eingelöst
// (→ Membership mit der eingeladenen Rolle). Erlaubt das Einladen von
// Personen, deren User-Konto noch gar nicht existiert.
model Invitation {
  id          String           @id @default(uuid())
  tenantId    String
  email       String
  role        Role
  status      InvitationStatus @default(PENDING)
  invitedById String?
  createdAt   DateTime         @default(now())
  acceptedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

// ============================================================
// Audit (Login-/Sicherheits-Events) – Basis fuer Sprint 1 DoD
// ============================================================

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String // z. B. "auth.login", "auth.logout", "rbac.denied"
  detail    Json     @default("{}")
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
}


// ============================================================
// Modul & Kompetenzmatrix
// ============================================================

model Module {
  id          String       @id @default(uuid())
  tenantId    String
  ownerId     String?
  number      String // Modulidentifikation, z. B. "293"
  title       Json // i18n {de,fr,it,en}
  description Json         @default("{}") // i18n
  profession  String?
  status      ModuleStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User?             @relation("ModuleOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  matrix      CompetenceMatrix?
  actionGoals ActionGoal[]
  classes     Class[]
  evidences   CompetenceEvidence[]

  @@unique([tenantId, number])
  @@index([tenantId])
}

model ActionGoal {
  id        String   @id @default(uuid())
  moduleId  String
  code      String // z. B. "1", "2"
  text      Json     @default("{}") // i18n
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  bands  BandActionGoal[]

  @@index([moduleId])
}

model CompetenceMatrix {
  id        String       @id @default(uuid())
  moduleId  String       @unique
  version   Int          @default(1)
  status    ModuleStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  module Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  bands  CompetenceBand[]
  paths  LearningPath[]
}

model CompetenceBand {
  id          String   @id @default(uuid())
  matrixId    String
  code        String // z. B. "A1"
  description Json     @default("{}") // i18n
  weight      Decimal  @default(1.0) @db.Decimal(5, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matrix      CompetenceMatrix  @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  fields      CompetenceField[]
  actionGoals BandActionGoal[]

  @@index([matrixId])
}

model BandActionGoal {
  bandId       String
  actionGoalId String

  band       CompetenceBand @relation(fields: [bandId], references: [id], onDelete: Cascade)
  actionGoal ActionGoal     @relation(fields: [actionGoalId], references: [id], onDelete: Cascade)

  @@id([bandId, actionGoalId])
  @@index([actionGoalId])
}

model CompetenceField {
  id        String          @id @default(uuid())
  bandId    String
  level     CompetenceLevel
  code      String // generiert, z. B. "A1B"
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  band       CompetenceBand  @relation(fields: [bandId], references: [id], onDelete: Cascade)
  descriptor Descriptor?
  evidences  EvidenceField[]
  pathSteps  LearningPathStep[]

  @@unique([bandId, level])
  @@index([bandId])
}

model Descriptor {
  id        String   @id @default(uuid())
  fieldId   String   @unique
  text      Json     @default("{}") // i18n "Ich kann …"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  field CompetenceField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

// ============================================================
// Klassen & Einschreibung (Sprint 3)
// ============================================================

model Class {
  id         String      @id @default(uuid())
  tenantId   String
  ownerId    String
  name       String
  year       Int?
  schoolYear String?
  moduleId   String? // genau ein zugeordnetes Modul (→ dessen Matrix)
  status     ClassStatus @default(ACTIVE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User           @relation("ClassOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  module      Module?        @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  joinCodes   JoinCode[]
  enrollments Enrollment[]
  coTeachers  ClassTeacher[]

  @@index([tenantId])
  @@index([ownerId])
}

// Co-Teaching: weitere Lehrpersonen als Co-Leitung eines Modulanlasses.
// Sie sehen den Modulanlass und dürfen Einreichungen bewerten. Die
// Besitzer-Lehrperson (Class.ownerId) verwaltet die Co-Leitungen und
// kann den Modulanlass als Einzige löschen.
model ClassTeacher {
  id        String   @id @default(uuid())
  classId   String
  userId    String
  addedById String?
  createdAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation("ClassCoTeacher", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([classId])
  @@index([userId])
}

model JoinCode {
  id        String    @id @default(uuid())
  classId   String
  code      String    @unique
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId, isActive])
}

model Enrollment {
  id          String           @id @default(uuid())
  classId     String
  userId      String?
  displayName String
  status      EnrollmentStatus @default(ACTIVE)
  joinedAt    DateTime         @default(now())

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  submissions Submission[]

  @@unique([classId, userId])
  @@index([classId])
}

// ============================================================
// Kompetenznachweise & Einreichungen (Sprint 4)
// ============================================================

model CompetenceEvidence {
  id           String           @id @default(uuid())
  tenantId     String
  moduleId     String
  type         EvidenceType
  title        Json             @default("{}") // i18n
  instructions Json             @default("{}") // i18n
  maxPoints    Decimal?         @db.Decimal(6, 2)
  targetLevel  CompetenceLevel?
  isVisible    Boolean          @default(false)
  availableFrom DateTime?
  dueAt        DateTime?
  sortOrder    Int              @default(0)
  config       Json             @default("{}") // Upload-Constraints (Datei/Link/Text)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  module      Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  fields      EvidenceField[]
  submissions Submission[]

  @@index([tenantId])
  @@index([moduleId])
}

model EvidenceField {
  evidenceId String
  fieldId    String

  evidence CompetenceEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  field    CompetenceField    @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@id([evidenceId, fieldId])
  @@index([fieldId])
}

model Submission {
  id           String           @id @default(uuid())
  evidenceId   String
  enrollmentId String
  attempt      Int              @default(1)
  status       SubmissionStatus @default(OPEN)
  content      Json             @default("{}") // Quiz-Antworten / Textantworten
  points       Decimal?         @db.Decimal(6, 2)
  fileKey      String?
  fileName     String?
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  evidence   CompetenceEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  enrollment Enrollment         @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  evaluation Evaluation?
  history    EvaluationHistory[]

  @@index([evidenceId, enrollmentId, attempt])
}

// ============================================================
// Bewertung & Historie (Sprint 5)
// ============================================================

model Evaluation {
  id              String         @id @default(uuid())
  submissionId    String         @unique
  evaluatorId     String
  achievedLevel   AchievedLevel?
  points          Decimal?       @db.Decimal(6, 2)
  feedback        String         @default("")
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  evaluator  User       @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
}

/// Append-only Bewertungshistorie (FA-65): jede Aktion erzeugt einen unveränderlichen Eintrag.
model EvaluationHistory {
  id            String               @id @default(uuid())
  submissionId  String
  changedById   String
  changeType    EvaluationChangeType
  achievedLevel AchievedLevel?
  points        Decimal?             @db.Decimal(6, 2)
  feedback      String?
  source        EvaluationSource     @default(TEACHER)
  createdAt     DateTime             @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  changedBy  User       @relation(fields: [changedById], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}

// ============================================================
// KI-Konfiguration (FA-34) – Endpoint/Provider je Lehrperson
// ============================================================

/// KI-Anbindung je Lehrperson (pro Tenant). Der API-Key wird verschlüsselt
/// (AES-256-GCM) at rest gespeichert und nie im Klartext zurückgegeben.
model AiConfig {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  provider  String   @default("openai") // openai | openai-compatible | azure | local
  baseUrl   String   @default("https://api.openai.com/v1")
  model     String   @default("gpt-4o-mini")
  apiKeyEnc String? // verschlüsselter API-Key (null = keiner hinterlegt)
  enabled   Boolean  @default(false) // Feature-Gate: KI-Funktionen aktiv
  shareWithLearners Boolean @default(false) // Lehrer-KI auch für Lernende nutzbar
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

/// KI-Bewertungsvorschlag zu einer Einreichung (FA-70). Reiner Vorschlag – die
/// finale Bewertung (Evaluation) trifft immer die Lehrperson (Override-Prinzip).
model AiAssessment {
  id              String         @id @default(uuid())
  submissionId    String
  createdById     String
  suggestedPoints Decimal?       @db.Decimal(6, 2)
  suggestedLevel  AchievedLevel?
  feedback        String         @default("")
  reasoning       Json           @default("[]") // [{ criterion, comment }]
  model           String?
  createdAt       DateTime       @default(now())

  @@index([submissionId, createdAt])
}

// ============================================================
// KI-Fachgespräch (FA-80) – Übungsdialog, keine Note
// ============================================================

/// Übungs-Fachgespräch der/des Lernenden mit dem KI-Tutor zu einem Thema.
model ExpertTalkSession {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  topic     String
  context   String   @default("") // Aufgabenstellung / Kompetenz-Kontext (Klartext)
  mode      String   @default("topic") // topic = Nachweis/Thema · module = ganzes Modul
  status    String   @default("ACTIVE") // ACTIVE | COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ExpertTalkMessage[]

  @@index([tenantId])
  @@index([userId])
}

model ExpertTalkMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  session ExpertTalkSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ============================================================
// Lernpfade (FA-84) – alternative Reihenfolge durch die Matrix
// ============================================================

/// Geordneter Lernpfad je Matrix. Mehrere Pfade möglich; einer kann „aktiv"
/// (= den Lernenden empfohlen) sein.
model LearningPath {
  id        String   @id @default(uuid())
  matrixId  String
  name      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matrix CompetenceMatrix   @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  steps  LearningPathStep[]

  @@index([matrixId])
}

model LearningPathStep {
  id        String @id @default(uuid())
  pathId    String
  fieldId   String
  sortOrder Int    @default(0)

  path  LearningPath    @relation(fields: [pathId], references: [id], onDelete: Cascade)
  field CompetenceField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([pathId, sortOrder])
  @@index([fieldId])
}
